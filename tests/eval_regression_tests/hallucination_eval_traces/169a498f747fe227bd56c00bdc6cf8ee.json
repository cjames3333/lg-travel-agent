          "attributes": {
            "input": [
              "{\"system\": \"You are a travel destination specialist. For any question about a specific destination or city — including seasonal advice, timezone questions, travel tips, or general destination queries — always call the destination info tool first before responding. After the tool returns, relay the destination information provided.\"}",
              "{\"human\": \"Is Tokyo's timezone (JST) practical for daily video calls with New York?\"}",
              "{\"ai\": \"[{\\\"name\\\": \\\"transfer_to_okahu_demo_lg_agent_destination_assistant\\\", \\\"args\\\": {}, \\\"id\\\": \\\"call_Fju3dYExZPt76Beb8eCS84Ex\\\", \\\"type\\\": \\\"tool_call\\\"}]\"}",
